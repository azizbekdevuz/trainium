# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trainium

# Auth
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_WEBHOOK_ENABLED=false

TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key

# Email
RESEND_API_KEY=re_your-resend-api-key

# Socket (required for real-time notifications)
# Server-side: Next.js HTTP calls to socket server (required in production)
SOCKET_SERVER_URL=http://localhost:4000
# Client-side: browser WebSocket URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
# Admin secret for socket server HTTP endpoints (X-Admin-Secret header)
SOCKET_ADMIN_SECRET=your-socket-admin-secret

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ISR Revalidation
REVALIDATE_SECRET=your-revalidate-secret

# --- Public file uploads (products, avatars, admin uploads) ---
# Local disk (default): absolute path recommended in production (Docker: UPLOADS_DIR=/data/uploads).
# Persistence: use a Docker named or bind-mounted volume on that path. compose down -v deletes named volumes.
# Logs: first request logs JSON line public-storage init (backend + path/bucket summary, no secrets).
# UPLOADS_DIR=/data/uploads
#
# Object storage (recommended for multi-instance or maximum durability): S3-compatible API.
# PUBLIC_FILE_STORAGE=s3
# S3_BUCKET=your-bucket
# S3_REGION=auto
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_KEY_PREFIX=uploads
# S3_FORCE_PATH_STYLE=true
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY also work for credentials.)
