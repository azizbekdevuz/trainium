{
  "extends": ["next/core-web-vitals"],
  "root": true,
  "settings": {
    "next": { "rootDir": "apps/web" }
  },
  "rules": {
    "@next/next/no-html-link-for-pages": ["off", "apps/web/src/app"]
  },
  "overrides": [
    {
      "files": ["apps/socket/**/*.js", "ecosystem.config.cjs"],
      "env": { "node": true },
      "rules": {
        "no-undef": "off"
      }
    }
  ]
}


