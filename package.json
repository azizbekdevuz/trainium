{
  "name": "trainium",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.6",
  "pnpm": {
    "overrides": {
      "tar": "^7.5.11",
      "socket.io-parser": "^4.2.6",
      "effect": "^3.20.0",
      "qs": "^6.14.2",
      "minimatch@^3.0.0": "3.1.5",
      "minimatch@^9.0.0": "9.0.7",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@^4.0.0": "4.0.4",
      "flatted@^3.0.0": "3.4.2",
      "path-to-regexp@0.1.12": "0.1.13",
      "path-to-regexp@8.2.0": "8.4.1",
      "brace-expansion@1.1.12": "1.1.13",
      "defu": "^6.1.5",
      "vite": "^8.0.5"
    }
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @apps/web dev",
    "dev:socket": "pnpm --filter @apps/socket dev",
    "build": "turbo run build",
    "start": "turbo run start --parallel",
    "start:web": "pnpm --filter @apps/web start",
    "start:socket": "pnpm --filter @apps/socket start",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs --fix",
    "lint:apps": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@prisma/client": "6.19.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.14",
    "prisma": "6.19.2",
    "turbo": "^2.5.8",
    "typescript-eslint": "^8.57.2"
  }
}
